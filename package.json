{
  "name": "trading-assistant",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "Varinder Singh Sandhu",
  "type": "module",
  "main": "index.js",
  "module": "ESNEXT",
  "scripts": {
    "check": "tsc --noEmit",
    "kite:options": "NODE_OPTIONS='--no-warnings' node --loader ts-node/esm src/data/kite-options.ts",
    "kite:token": "NODE_OPTIONS='--no-warnings' node --loader ts-node/esm src/scripts/kite-access-token.ts",
    "watch": "NODE_OPTIONS='--no-warnings' tsx src/cli/cli.ts watch",
    "analyze": "NODE_OPTIONS='--no-warnings' tsx src/cli/cli.ts analyze",
    "dashboard:dev": "cd web && npm run dev",
    "dashboard:build": "cd web && npm run build",
    "db:migrate": "NODE_OPTIONS='--no-warnings' tsx src/db/migrate.ts",
    "db:close-all": "NODE_OPTIONS='--no-warnings' tsx src/scripts/close-all-trades.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.10.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "kiteconnect": "^5.3.0",
    "kysely": "^0.29.2",
    "openai": "^6.35.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.6"
  }
}
